<script>
require(['jquery'], function($) {
    var ajaxUrl = '<?= $escaper->escapeUrl($createAjaxUrl) ?>';
    var formKey = '<?= $escaper->escapeHtmlAttr($formKey) ?>';

    // Update search count
    function updateCount() {
        var total = $('.soldx-tree-node').length;
        var visible = $('.soldx-tree-node').filter(function() {
            return $(this).is(':visible');
        }).length;
        $('.soldx-cat-search-count').text(visible + ' / ' + total);
    }
    updateCount();

    // Live search — match name or path, show parents of matching children
    $('#soldx-cat-search').on('input', function() {
        var query = $(this).val().toLowerCase().trim();

        if (query === '') {
            $('.soldx-tree-node').show();
            $('.soldx-tree-node').removeClass('collapsed');
            updateCount();
            return;
        }

        $('.soldx-tree-node').each(function() {
            var name = $(this).data('name') || '';
            var path = $(this).data('path') || '';
            var match = name.indexOf(query) !== -1 || path.indexOf(query) !== -1;
            $(this).toggle(match);
        });

        // Ensure ancestors of visible nodes are also visible and expanded
        $('.soldx-tree-node:visible').each(function() {
            $(this).parents('.soldx-tree-node').show().removeClass('collapsed');
        });

        updateCount();
    });

    // Single "+ Studio" create
    function handleCreate(btn) {
        var catName = btn.data('cat-name');
        var catId = btn.data('cat-id');
        var select = btn.siblings('.soldx-cat-select');
        var currentVal = select.val();
        var idParent = currentVal || '';

        btn.prop('disabled', true).find('span').text('...');

        $.ajax({
            url: ajaxUrl,
            type: 'POST',
            data: {
                form_key: formKey,
                designation: catName,
                categoryId: catId,
                idParent: idParent
            },
            dataType: 'json'
        }).done(function(data) {
            if (data.success) {
                var newId = data.category.id;
                var newLabel = data.category.designation;
                var prefix = data.category.idParent ? '— ' : '';
                $('.soldx-cat-select').each(function() {
                    if ($(this).find('option[value="' + newId + '"]').length === 0) {
                        $(this).append('<option value="' + newId + '">' + prefix + newLabel + '</option>');
                    }
                });
                select.val(newId);
                btn.find('span').text('Created');
                setTimeout(function() { btn.prop('disabled', false).find('span').text('+ Studio'); }, 1500);
            } else {
                alert(data.message || 'Failed to create category');
                btn.prop('disabled', false).find('span').text('+ Studio');
            }
        }).fail(function() {
            alert('Request failed');
            btn.prop('disabled', false).find('span').text('+ Studio');
        });
    }

    // Direct handler — must not use delegation because the
    // .soldx-cat-btn stopPropagation() above would block it.
    $('.soldx-create-cat-btn').on('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        handleCreate($(this));
    });

    // Prevent tree toggle when clicking on row actions
    $('.soldx-cat-select, .soldx-cat-btn').on('click', function(e) {
        e.stopPropagation();
    });

    // Batch "Create All Unmapped"
    $('#soldx-create-all').on('click', function(e) {
        e.preventDefault();
        var btn = $(this);
        var rows = [];

        $('.soldx-cat-select').each(function() {
            var select = $(this);
            var createBtn = select.siblings('.soldx-create-cat-btn');
            if ((!select.val() || select.val() === '') && createBtn.length) {
                rows.push({btn: createBtn});
            }
        });

        if (rows.length === 0) {
            alert('No unmapped categories to create.');
            return;
        }

        btn.prop('disabled', true).find('span').text('Creating...');

        var created = 0, failed = 0, idx = 0;

        function processNext() {
            if (idx >= rows.length) {
                btn.find('span').text('Done (' + created + ' created, ' + failed + ' failed)');
                setTimeout(function() {
                    btn.prop('disabled', false).find('span').text('Create All Unmapped in Studio');
                }, 2000);
                return;
            }

            var r = rows[idx];
            idx++;
            r.btn.prop('disabled', true).find('span').text('...');

            handleCreateAsync(r.btn, function(success) {
                if (success) {
                    created++;
                    r.btn.find('span').text('Created');
                } else {
                    failed++;
                    r.btn.find('span').text('Failed');
                }
                setTimeout(processNext, 300);
            });
        }

        function handleCreateAsync(btn, callback) {
            var catName = btn.data('cat-name');
            var catId = btn.data('cat-id');
            var select = btn.siblings('.soldx-cat-select');

            $.ajax({
                url: ajaxUrl,
                type: 'POST',
                data: {
                    form_key: formKey,
                    designation: catName,
                    categoryId: catId,
                    idParent: ''
                },
                dataType: 'json'
            }).done(function(data) {
                if (data.success) {
                    var newId = data.category.id;
                    var newLabel = data.category.designation;
                    var prefix = data.category.idParent ? '— ' : '';
                    $('.soldx-cat-select').each(function() {
                        if ($(this).find('option[value="' + newId + '"]').length === 0) {
                            $(this).append('<option value="' + newId + '">' + prefix + newLabel + '</option>');
                        }
                    });
                    select.val(newId);
                    callback(true);
                } else {
                    callback(false);
                }
            }).fail(function() {
                callback(false);
            });
        }

        processNext();
    });
});
</script>
