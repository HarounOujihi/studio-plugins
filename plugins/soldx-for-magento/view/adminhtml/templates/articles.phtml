<script>
require(['jquery'], function($) {
    // Select all
    $('#soldx-select-all').on('change', function() {
        $('.soldx-row-check').prop('checked', this.checked);
    });

    // Sync single product
    $(document).on('click', '.soldx-sync-btn', function(e) {
        e.preventDefault();
        var btn = $(this);
        var productId = btn.data('product-id');
        btn.prop('disabled', true).find('span').text('...');

        $.ajax({
            url: btn.data('url'),
            type: 'POST',
            data: { form_key: btn.data('form-key'), product_id: productId },
            dataType: 'json'
        }).done(function(data) {
            if (data.success) {
                location.reload();
            } else {
                alert(data.error || data.message || 'Sync failed');
                btn.prop('disabled', false).find('span').text('Sync');
            }
        }).fail(function() {
            alert('Request failed');
            btn.prop('disabled', false).find('span').text('Sync');
        });
    });

    // Sync all (sequential AJAX)
    $('#soldx-sync-all-btn').on('click', function() {
        var btn = $(this);
        var url = btn.data('url');
        var formKey = btn.data('form-key');
        var ids = [];

        $('.soldx-row-check:checked').each(function() {
            ids.push($(this).val());
        });

        if (ids.length === 0) {
            $('.soldx-row-check').each(function() {
                ids.push($(this).val());
            });
        }

        if (ids.length === 0) return;

        btn.prop('disabled', true).text('Syncing ' + ids.length + ' products...');

        var idx = 0;
        var success = 0, failed = 0;

        function syncNext() {
            if (idx >= ids.length) {
                btn.text('Done: ' + success + ' ok, ' + failed + ' failed');
                setTimeout(function() { location.reload(); }, 1500);
                return;
            }
            var pid = ids[idx];
            idx++;
            $.ajax({
                url: url,
                type: 'POST',
                data: { form_key: formKey, product_id: pid },
                dataType: 'json'
            }).done(function(data) {
                if (data.success) success++; else failed++;
            }).fail(function() {
                failed++;
            }).always(function() {
                btn.text('Syncing... (' + idx + '/' + ids.length + ')');
                syncNext();
            });
        }
        syncNext();
    });
});
</script>
