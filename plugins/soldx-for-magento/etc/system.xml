<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="soldx" translate="label" sortOrder="200">
            <label>Soldx</label>
        </tab>

        <section id="soldx" translate="label" type="text" sortOrder="10" showInDefault="1"
                 showInWebsite="0" showInStore="0">
            <label>Soldx Studio Integration</label>
            <tab>soldx</tab>
            <resource>Soldx_Integration::config</resource>

            <group id="connection" translate="label" sortOrder="10" showInDefault="1"
                   showInWebsite="0" showInStore="0">
                <label>Connection</label>

                <field id="api_base_url" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Studio URL</label>
                    <comment>e.g. https://studio.soldx.test</comment>
                </field>

                <field id="api_key" translate="label" type="password" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Key</label>
                    <comment>64-character hex key from Studio</comment>
                </field>
            </group>

            <group id="auth_result" translate="label" sortOrder="20" showInDefault="1"
                   showInWebsite="0" showInStore="0">
                <label>Authentication Result</label>

                <field id="integration_id" translate="label" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Integration ID</label>
                </field>

                <field id="integration_name" translate="label" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Integration Name</label>
                </field>

                <field id="connected_at" translate="label" type="label" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Connected At</label>
                </field>

                <field id="status" translate="label" type="label" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Status</label>
                </field>
            </group>

            <group id="sync" translate="label" sortOrder="30" showInDefault="1"
                   showInWebsite="0" showInStore="0">
                <label>Synchronisation</label>

                <field id="auto_sync" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Automatic Sync</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Push products to Studio automatically on save.</comment>
                </field>

                <field id="default_tax_rate" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Default Tax Rate (%)</label>
                    <comment>Used when product tax class is not determinable.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
